{
  "_schema_version": "0.1.0",
  "_reference": "IMO FAL Convention Annex, FAL Form 1 — General Declaration (Rev.2)",
  "_fill_types": {
    "direct": "Value copied verbatim from maridb source field",
    "computed": "Derived from one or more source fields by deterministic rule",
    "llm_summarise": "Free-text summary generated by LLM from structured source data",
    "agent_entry": "Entered manually by ship agent at generation time",
    "constant": "Fixed value defined in port-specific configuration"
  },
  "_pii_boundary": "Crew names, passport numbers, and dates of birth are NOT in this field map. They are entered client-side (WASM) and never transit the server.",

  "fields": [
    {
      "fal_field_number": "1",
      "fal_field_name": "Name and description of ship",
      "fill_type": "direct",
      "maridb_source": "vessel.vessel_name",
      "llm_required": false,
      "notes": "Full registered name as per IMO record"
    },
    {
      "fal_field_number": "2",
      "fal_field_name": "IMO number",
      "fill_type": "direct",
      "maridb_source": "vessel.imo_number",
      "llm_required": false,
      "notes": "7-digit IMO ship identification number"
    },
    {
      "fal_field_number": "3",
      "fal_field_name": "Call sign",
      "fill_type": "direct",
      "maridb_source": "vessel.call_sign",
      "llm_required": false,
      "notes": null
    },
    {
      "fal_field_number": "4",
      "fal_field_name": "Voyage number",
      "fill_type": "direct",
      "maridb_source": "voyage.voyage_number",
      "llm_required": false,
      "notes": null
    },
    {
      "fal_field_number": "5",
      "fal_field_name": "Port of arrival/departure",
      "fill_type": "direct",
      "maridb_source": "voyage.port_of_arrival.name",
      "llm_required": false,
      "notes": "UN/LOCODE also written: voyage.port_of_arrival.unlocode"
    },
    {
      "fal_field_number": "6",
      "fal_field_name": "Date and time of arrival/departure",
      "fill_type": "direct",
      "maridb_source": "voyage.eta_utc",
      "llm_required": false,
      "notes": "Converted to local port timezone at render time. Departure uses voyage.etd_utc"
    },
    {
      "fal_field_number": "7",
      "fal_field_name": "Brief description of the cargo",
      "fill_type": "llm_summarise",
      "maridb_source": "cargo.items[*].description",
      "llm_required": true,
      "notes": "LLM summarises multiple cargo line items into a single concise description (≤ 200 chars). Dangerous goods flag forces inclusion of DG class if cargo.dangerous_goods_onboard = true"
    },
    {
      "fal_field_number": "8",
      "fal_field_name": "Flag State of ship",
      "fill_type": "direct",
      "maridb_source": "vessel.flag_state_name",
      "llm_required": false,
      "notes": "Full country name. ISO 3166-1 alpha-3 code in vessel.flag_state"
    },
    {
      "fal_field_number": "9",
      "fal_field_name": "Name of master",
      "fill_type": "agent_entry",
      "maridb_source": null,
      "llm_required": false,
      "notes": "PII — entered by agent at generation time, rendered client-side via WASM, never stored server-side"
    },
    {
      "fal_field_number": "10",
      "fal_field_name": "Last port of call",
      "fill_type": "direct",
      "maridb_source": "voyage.last_port_of_call.name",
      "llm_required": false,
      "notes": "UN/LOCODE: voyage.last_port_of_call.unlocode"
    },
    {
      "fal_field_number": "11",
      "fal_field_name": "Next port of call",
      "fill_type": "direct",
      "maridb_source": "voyage.next_port_of_call.name",
      "llm_required": false,
      "notes": "UN/LOCODE: voyage.next_port_of_call.unlocode"
    },
    {
      "fal_field_number": "12",
      "fal_field_name": "Gross tonnage",
      "fill_type": "direct",
      "maridb_source": "vessel.gross_tonnage",
      "llm_required": false,
      "notes": null
    },
    {
      "fal_field_number": "13",
      "fal_field_name": "Net tonnage",
      "fill_type": "direct",
      "maridb_source": "vessel.net_tonnage",
      "llm_required": false,
      "notes": null
    },
    {
      "fal_field_number": "14",
      "fal_field_name": "Position of ship in port (berth/anchorage)",
      "fill_type": "direct",
      "maridb_source": "voyage.berth_requested",
      "llm_required": false,
      "notes": "Falls back to voyage.anchorage_requested if berth is null"
    },
    {
      "fal_field_number": "15",
      "fal_field_name": "Number of crew members",
      "fill_type": "direct",
      "maridb_source": "voyage.crew_count",
      "llm_required": false,
      "notes": "Count only — individual crew data is PII and handled client-side"
    },
    {
      "fal_field_number": "16",
      "fal_field_name": "Number of passengers",
      "fill_type": "direct",
      "maridb_source": "voyage.passenger_count",
      "llm_required": false,
      "notes": null
    },
    {
      "fal_field_number": "17",
      "fal_field_name": "Remarks",
      "fill_type": "llm_summarise",
      "maridb_source": ["voyage.waste_to_deliver", "voyage.waste_types", "voyage.stowaways_count"],
      "llm_required": true,
      "notes": "LLM generates a structured remarks block covering: waste delivery status, stowaways declaration (0 = none), and any voyage-specific notes from agent. Output is deterministic given the same inputs."
    },
    {
      "fal_field_number": "18",
      "fal_field_name": "Date and place of issue",
      "fill_type": "computed",
      "maridb_source": null,
      "llm_required": false,
      "notes": "Generated at render time: current UTC date + port_of_arrival.name"
    },
    {
      "fal_field_number": "19",
      "fal_field_name": "Signature",
      "fill_type": "agent_entry",
      "maridb_source": null,
      "llm_required": false,
      "notes": "Ship master or authorised agent signature. In digital submission: Ed25519 signature of document hash"
    }
  ],

  "fal_form_1_completeness": {
    "total_fields": 19,
    "direct_fill": 11,
    "computed": 1,
    "llm_summarise": 2,
    "agent_entry": 3,
    "constant": 0,
    "pii_fields": ["9 (master name)", "19 (signature)"],
    "llm_fields": ["7 (cargo description)", "17 (remarks)"]
  }
}
